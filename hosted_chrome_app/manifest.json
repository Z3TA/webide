{
	"name": "JZedit",
	"description": "Make JavaScript/Node.js apps on your Chromebook! Early alpha release. Send feedback and bug reports to zeta@zetafiles.org",
	"version": "1.0.0",
	"manifest_version": 2,
	
	"icons": {
		"64": "jz64.png",
		"128": "jz128.png",
		"192": "jz192.png",
		"512": "jz512.png"
	},
	
	"permissions": [
		"clipboardRead",
		"clipboardWrite",
		"unlimitedStorage"
	],
	
	"app": {
		"urls": [
			"https://webide.se/"
		],
		"launch": {
			"web_url": "https://webide.se/",
			"container": "panel"
		}
	}
}
