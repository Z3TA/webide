{
	"name": "WebIDE",
	"short_name": "webide.se",
	"description": "New: Editor/IDE for creating progressive web apps, and web sites. (JavaScript, Node JS, HTML CSS)",
	"version": "400",
	"manifest_version": 2,
	
	"icons": {
		"128": "android-chrome-128x128.png",
		"192": "android-chrome-192x192.png",
		"512": "android-chrome-512x512.png"
	},
	
	"permissions": [
		"clipboardRead",
		"clipboardWrite",
		"unlimitedStorage"
	],
	
	"app": {
		"urls": [
			"https://webide.se/"
		],
		"launch": {
			"web_url": "https://webide.se/",
			"container": "panel"
		}
	}
}
