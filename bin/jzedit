#!/usr/bin/env node

/*
	This script can be used in place of "editor".
	
	jzedit [filepath]
	(or pipe to it)
	
	Installation (optional, if npm didn't do this for us):
	* Make sure this file is executable: chmod +x jzedit
	* Add this folder to PATH
	   * Or copy this file to /usr/bin/: sudo cp jzedit /usr/bin/
	   * Or add the jzedit location to .profile or .bashrc :  export PATH=$PATH:/path/to/bin/jzedit
	
	todo:
	Some programs like "crontab -e" assumes we are done when exiting ...
	Solution: Keep the program running, and don't exit until we get a notice that the file has been closed !?
	
*/

var module_path = require("path");
var module_net = require("net");

var DEFAULT = require("../server/default_settings.js");
var STDIN_PORT = DEFAULT.stdin_channel_port;

var JZEDIT_LOCATION = module_path.resolve(__dirname, "../"); // Path to the jzedit folder (where package.json is located)
console.log("JZEDIT_LOCATION=" + JZEDIT_LOCATION);


var EDITOR_STARTED = false;

//console.log("process.argv=" + process.argv);

function main() {

	var args = process.argv;
	args.shift(); // Remove the path to node
	args.shift(); // Remove the path to this script
	args = args.join(" ");
	
	if(args.length > 0) {
		// Asume args is a file path. Resolve the path
		var workingDir = process.cwd();
		var filePath = module_path.resolve(workingDir, args);
	}

	var argsSent = false;
	
	var stdinData = '';
	
	var stdinChannel;
	
	var stdinStream = process.stdin;
	stdinStream.on('readable', function() {
		console.log("stdin stream readable!");
		/*
			readable will be called on program start 
			and after pressing enter while the program is running
			
*/
		var chunk = this.read();
		// Note: Reading data will remove it from the internal buffer and it will not be piped
		
		if (chunk === null) {
			var stdinStreamHasData = false;
			console.log("No data in stdin stream.");
			
			
		} else {
			var stdinStreamHasData = true;
			console.log("stdin stream has data!");
			
			stdinData += chunk;
			
		}
		
		/*
			Connect to the editor server's stdin channel
*/
		console.log("stdinChannel=" + !!stdinChannel + 
		" stdinChannel.destroyed=" + (stdinChannel && stdinChannel.destroyed) + 
		" argsSent=" + argsSent + 
		" stdinStreamHasData=" + stdinStreamHasData +
		" stdinChannel.connecting = " + (stdinChannel && stdinChannel.connecting) );
		
		if( (!stdinChannel || stdinChannel.destroyed) && 
		(!argsSent || stdinStreamHasData) && 
		!(stdinChannel && stdinChannel.connecting) ) connectToStdinChannel(stdinStreamHasData);
		
		
	});
	stdinStream.on('end', function() {
		console.log("stdin stream ended!");
		//if(stdinChannel) stdinChannel.end();
		
	});
	
	
	function connectToStdinChannel(pipeStdin, secondTry) {
		console.log("(re)connecting to editor server stdin channel. secondTry=" + secondTry + " ...");
		stdinChannel = module_net.createConnection({port: STDIN_PORT});
		stdinChannel.on("error", stdinChannelError);
		stdinChannel.on("connect", stdinChannelConnected);
		stdinChannel.on("close", stdinChannelClosed);
		
		function stdinChannelError(err) {
			if(err.code == "ECONNREFUSED") {
				if(!secondTry) {
					console.log("Attempting to start the editor ...");
					startEditor(function editorStarted(err) {
						if(err) console.log(err.message);
						else connectToStdinChannel(pipeStdin, true);
												
					});
				}
				else console.log("Already tried starting the editor!");
			}
			else console.error(err);
		}
		
		function stdinChannelConnected() {
			console.log("Connected to editor server stdin channel. pipeStdin=" + pipeStdin);
			
			// When connecting we Must always send the arguments even if they are empty
			stdinChannel.write((filePath || args) + "\n");
			argsSent = true;
			
			if(stdinData.length > 0) stdinChannel.write(stdinData);
			else console.log("No stdinData to send");
			
			if(pipeStdin) {
				console.log("Piping stdin to editor ...");
				stdinStream.pipe(stdinChannel);
				// When piping, the socket will automatically end when the piped stream end!
			}
			else {
				console.log("Closing stdin channel because pipeStdin=" + pipeStdin);
				stdinChannel.end();
				if(!EDITOR_STARTED) process.exit(0);
			}
		}
		
		function stdinChannelClosed(hadError) {
			console.log("stdin channel closed. hadError=" + hadError);
		}
		
	}
	
}

function startEditor(callback) {
	
	var spawn = require('child_process').spawn;
	
	var editor = spawn( JZEDIT_LOCATION + "/start.js", ["-no-module-check", "-local"] , { env: process.env } );
	
	EDITOR_STARTED = true;

	editor.on("error", function editorError(err) {
		console.log("Editor error: " + err.message);
		if(callback) {
			callback( err );
			callback = null;
		}
	});
	
	editor.on("close", function editorClosed(code) {
		console.log("editor closed. code=" + code);
		if(callback) {
			callback( new Error("Editor closed! code=" + code) );
			callback = null;
		}
		process.exit(); // Always exit (this script) when the editor exit
	});
	
	editor.stdout.on("data", function editorStdout(data) {
		//console.log("editor stdout: " + data);
		editorLog(data);
	});
	
	editor.stderr.on("data", function editorStderr(data) {
		//console.log("Editor stderr: " + data);
		editorLog(data);
	});

	function editorLog(data) {

		if(typeof data == "object") data = data.toString();

		var reStdinChannel = /stdin channel listening on port (\d+)/;
		var match = data.match(reStdinChannel);
		if(match) {
			if(match[1] != STDIN_PORT) STDIN_PORT = match[1];
			
			callback(null);
			callback = null;
			
			// Don't exit until the editor exit's
			//editor.ref();
			
			
		}
	}
}


main();
