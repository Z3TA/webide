<?xml version="1.0" encoding="UTF-8" ?>

<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
	<channel>
		<title>Johan Zetterberg</title>
		<description>Personal homepage and blog</description>
		<link>http://webtigerteam.com/johan/en/</link>
		<atom:link href="http://webtigerteam.com/johan/rss_en.xml" rel="self" type="application/rss+xml" />
		<?JS
		
			var moment = require("moment");
			var blog;
			var blogEntries = document.folder.folders["en"].folders["blog"].latest().documents;

			for(var file in blogEntries) {
				
				blog = blogEntries[file];

				document.write('\t\t<item>\n');
				
	document.write('\t\t\t<title>' + blog.title + '</title>\n');
				document.write('\t\t\t<description>' + blog.lead.replace(/<[^>]*>/g, " ") + '</description>\n');
				document.write('\t\t\t<guid>http://webtigerteam.com/johan/' + blog.url + '</guid>\n');
				document.write('\t\t\t<pubDate>' + moment(blog.created).format("ddd, D MMM YYYY HH:mm:ss ZZ") + '</pubDate>\n');
				
				document.write('\t\t</item>\n');

			}
		
		?>
		
	</channel>
</rss>


