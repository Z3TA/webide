
#include <tunables/global>

%HOME%%USERNAME%/usr/bin/hg {
  #include <abstractions/base>
  #include <abstractions/python>

  deny capability dac_override,
  deny capability dac_read_search,

  network inet dgram,
  network inet stream,
  network inet6 dgram,

  #/dev/tty rw,
  %HOME%%USERNAME%/** rw,
  #/usr/bin/python2.7 ix,

}
