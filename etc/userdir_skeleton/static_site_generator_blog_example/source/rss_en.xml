<?xml version="1.0" encoding="UTF-8" ?>

<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
	<channel>
		<title>My blog</title>
<description>My personal homepage and blog</description>

<!-- CHANGE THESE LINKS TO YOUR OWN URL's (AND ALSO BELOW)-->
<link>http://%USERNAME%.%DOMAIN%/</link>
<atom:link href="http://%USERNAME%.%DOMAIN%/rss_en.xml" rel="self" type="application/rss+xml" />

		<?JS
		
			var moment = require("moment");
			var blog;
			var blogEntries = document.folder.folders["blog"].latest();

blogEntries.forEach(function (blog) {
	
	document.write('\n\t\t<item>\n');
	
	document.write('\t\t\t<title>' + blog.title + '</title>\n');
	document.write('\t\t\t<description>' + blog.lead.replace(/<[^>]*>/g, " ") + '</description>\n');
	// NEED TO CHANGE URL HERE TOO:
	document.write('\t\t\t<guid>http://%USERNAME%.%DOMAIN%' + blog.url + '</guid>\n');
	document.write('\t\t\t<pubDate>' + moment(blog.created).format("ddd, D MMM YYYY HH:mm:ss ZZ") + '</pubDate>\n');
	
	document.write('\t\t</item>\n');
	
});

?>

</channel>
</rss>


