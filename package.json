{
  "name": "webide.se",
  "main": "main.js",
  "window": {
    "title": "WebIDE",
    "show": true,
    "icon": "client/gfx/logo.svg",
    "toolbar": true,
    "frame": true,
    "transparent": false,
    "always-on-top": false
  },
  "bin": {
    "webide": "./bin/webide"
  },
  "private": true,
  "license": "SEE LICENSE IN LICENSE.txt",
  "description": "A text/code editor for JavaScript made in JavaScript",
  "keywords": [
    "editor",
    "IDE"
  ],
  "version": "1.0.0",
  "author": "Johan Zetterberg <zeta@zetafiles.org>",
  "dependencies": {
    "busboy": "^0.3.1",
    "dirname": "https://github.com/Z3TA/nwjs_dirname/tarball/master",
    "ftp": "https://github.com/Z3TA/node-ftp/tarball/master",
    "generate-password": "^1.5.1",
    "http-proxy": "^1.18.1",
    "iconv-lite": "https://github.com/Z3TA/iconv-lite/tarball/master",
    "jschardet": "^1.6.0",
    "mammoth": "^1.4.9",
    "marked": "^0.7.0",
    "ncp": "^2.0.0",
    "sockjs": "^0.3.20"
  },
  "optionalDependencies": {
    "nodemailer": "^2.6.4",
    "mysql2": "^1.6.5",
    "nodemailer-smtp-transport": "^2.7.2",
    "posix": "^4.1.2",
    "ps-node": "^0.1.6",
    "node-pty": "^0.9.0",
    "ssh2": "^0.8.9",
    "vscode-jsonrpc": "^4.0.0",
    "nodehun": "^2.0.12",
    "ws": "^6.2.1"
  },
  "repository": {
    "type": "Mercurial",
    "url": "http://hg.webtigerteam.com/repo/webide/"
  },
  "devDependencies": {
    "html-minifier": "^4.0.0",
    "uglify-js": "^3.7.2",
    "uglifycss": "^0.0.29"
  },
  "scripts": {
    "start": "node ./start.js -local",
    "server": "node ./server/server.js --loglevel=6 --username=admin --password=admin --ip=127.0.0.1 --port=8099",
    "webide-dev": "sudo node ./server/server.js --domain=webide-dev.se --host=webide-dev.se --ip=127.0.0.1 --port=8099"
  }
}
